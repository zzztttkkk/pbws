{
    "version": "0.2.0",
    "configurations": [
        {
            "request": "launch",
            "name": "Launch Program",
            "type": "node",
            "cwd": "${workspaceFolder}",
            "env": {},
            "runtimeExecutable": "deno",
            "runtimeArgs": [
                "test",
                "--unstable",
                "--inspect-wait",
                "--inspect-brk",
                "--allow-all",
                "--no-check",
                "${file}"
            ],
            "attachSimplePort": 9229
        }
    ]
}