{
  "tasks": {},
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "protobufjs": "npm:protobufjs@^8.7.1",
    "reflect-metadata": "npm:reflect-metadata@^0.2.2"
  },
  "compilerOptions": {
    "noImplicitAny": false,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-explicit-any",
        "ban-types",
        "require-await"
      ]
    }
  }
}