{
  "tasks": {},
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/cache": "jsr:@std/cache@^0.2.3",
    "protobufjs": "npm:protobufjs@^8.7.1"
  },
  "compilerOptions": {
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-explicit-any",
        "ban-types",
        "require-await"
      ]
    }
  }
}